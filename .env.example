# Supabase project credentials.
# Copy this file to `.env` and fill in the values from your project's
# Settings -> API page. The anon (public) key is safe to ship in the client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Android Google Maps key (Maps SDK for Android must be enabled in Google Cloud).
# Baked into the native build at prebuild time. Not needed for iOS/Apple Maps.
GOOGLE_MAPS_API_KEY=your-android-google-maps-api-key
